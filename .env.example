# Base URL for the support API backend.
# In production, set this to your actual API server URL.
# Defaults to "/api" (proxied via the web server) when not set.
VITE_API_BASE_URL=/api

# Optional: switch support data source to StreamLine directly.
# Set to "streamline" to route support API calls through StreamLine.
# Leave unset (or any other value) to keep using VITE_API_BASE_URL.
# VITE_SUPPORT_DATA_SOURCE=streamline

# Optional StreamLine API settings (used only when VITE_SUPPORT_DATA_SOURCE=streamline).
# Example: https://streamline.example.com/api
# VITE_STREAMLINE_API_BASE_URL=

# Optional bearer token for StreamLine API requests.
# VITE_STREAMLINE_API_TOKEN=
